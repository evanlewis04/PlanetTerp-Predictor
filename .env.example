# Runtime settings
PLANETTERP_MAX_PROFESSORS=1000
PLANETTERP_MIN_REVIEWS=10
PLANETTERP_PROFESSORS_PER_BATCH=100
PLANETTERP_RANDOM_STATE=42
PLANETTERP_TEST_SIZE=0.2
PLANETTERP_CV_FOLDS=10
PLANETTERP_RIDGE_ALPHAS=0.01,0.1,1.0,10.0,100.0

# Output settings
PLANETTERP_OUTPUT_DIR=outputs
PLANETTERP_FIGURE_DPI=300
PLANETTERP_FIGURE_FORMAT=png
PLANETTERP_LOG_LEVEL=INFO
PLANETTERP_PROGRESS_INTERVAL=100
